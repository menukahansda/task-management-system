        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const token = pm.collectionVariables.get(\"token\");\r",
              "\r",
              "pm.request.headers.upsert({\r",
              "    key: \"Authorization\",\r",
              "    value: `Bearer ${token}`\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
